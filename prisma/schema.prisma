generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Merchant {
  id              String       @id @default(uuid())
  name            String
  slug            String       @unique
  customDomain    String?      @unique
  phone           String
  pin             String       @default("1234") // Simple login PIN for MVP
  theme           String       @default("light")
  layout          String       @default("grid")
  isOpen          Boolean      @default(true)
  isActive        Boolean      @default(true)
  subscriptionTier String      @default("Free") // Phase 11
  coverImageUrl   String?
  welcomeMessage  String?
  deliveryFee     Int          @default(0)
  freeDeliveryThreshold Int?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  products        Product[]
  orders          Order[]
  promos          PromoCode[]
  staff           Staff[]
}

model Staff {
  id          String   @id @default(uuid())
  name        String
  phone       String   @unique
  pin         String
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model PlatformSettings {
  id                  String   @id @default("global")
  broadcastMessage    String?
}

model PromoCode {
  id              String   @id @default(uuid())
  code            String
  discountPercent Int
  isActive        Boolean  @default(true)
  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId      String
}

model Product {
  id          String           @id @default(uuid())
  name        String
  description String?
  price       Float
  imageUrl    String
  category    String           @default("Uncategorized")
  isFeatured  Boolean          @default(false)
  trackStock  Boolean          @default(false)
  stockCount  Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  variants    ProductVariant[]
  merchant    Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId  String
}

model ProductVariant {
  id        String   @id @default(uuid())
  name      String   // e.g., "Small", "Large", "Red"
  price     Float    // Price override for this variant
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

model Order {
  id              String      @id @default(uuid())
  customerName    String
  customerAddress String
  totalAmount     Float
  status          String      @default("Pending") // Pending, Completed, Cancelled
  createdAt       DateTime    @default(now())
  merchant        Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId      String
  items           OrderItem[]
}

model OrderItem {
  id          String  @id @default(uuid())
  productName String
  quantity    Int
  price       Float
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
}
